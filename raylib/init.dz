let checkCollisionCircleRec = rl.checkCollisionCircleRec
let checkCollisionPointRec = rl.checkCollisionPointRec
let getScreenToWorld2D = rl.getScreenToWorld2D
let getWorldToScreen2D = rl.getWorldToScreen2D

# --- Window class wrapper ---
class Window
    init(w, h, title)
        assert.number(w, "width")
        assert.number(h, "height")
        assert.string(title, "title")
        initWindow(w, h, title)
        self.width = w
        self.height = h
    end

    isOpen()
        return !shouldClose()
    end

    begin()
        beginDrawing()
    end

    finish()
        endDrawing()
    end

    clear(color)
        clearBackground(color)
    end

    close()
        closeWindow()
    end

    setFPS(fps)
        setTargetFPS(fps)
    end

    setTitle(title)
        setWindowTitle(title)
    end

    setSize(w, h)
        setWindowSize(w, h)
        self.width = w
        self.height = h
    end

    getFPS()
        return getFPS()
    end
end