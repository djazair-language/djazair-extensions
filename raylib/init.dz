# --- Re-export Types ---
let Vector2 = types.Vector2
let Color   = types.Color

# --- Re-export Shapes ---
let Circle    = shapes.Circle
let Rectangle = shapes.Rectangle

# --- Re-export Media ---
let Texture = media.Texture
let Text    = media.Text
let Sound   = media.Sound
let Audio   = media.Audio
let Font    = media.Font
let Music   = media.Music

# --- Re-export Camera ---
let Camera2D = cam.Camera2D

# --- Internal Helper ---
fn _extractColor(c)
    if rl.isColor(c)
        return c.raw
    end
    return c
end

# --- Standalone API Functions ---
let initWindow      = rl.init
let closeWindow     = rl.close
let shouldClose     = rl.shouldClose
let setTargetFPS    = rl.setTargetFPS
let beginDrawing    = rl.beginDrawing
let drawCircleLines = rl.drawCircleLines
let drawLine        = rl.drawLine
let endDrawing      = rl.endDrawing

fn clearBackground(color)
    rl.clearBackground(_extractColor(color))
end

fn drawText(text, x, y, size, color)
    assert.string(text, "text")
    assert.number(x, "x")
    assert.number(y, "y")
    assert.number(size, "size")
    rl.drawText(text, x, y, size, _extractColor(color))
end

fn drawRectangle(x, y, w, h, color)
    rl.drawRectangle(x, y, w, h, _extractColor(color))
end

fn drawCircle(x, y, radius, color)
    rl.drawCircle(x, y, radius, _extractColor(color))
end

fn drawCircleLines(x, y, radius, color)
    rl.drawCircleLines(x, y, radius, _extractColor(color))
end

fn drawLine(x1, y1, x2, y2, color)
    rl.drawLine(x1, y1, x2, y2, _extractColor(color))
end

fn drawLineEx(x1, y1, x2, y2, thickness, color)
    rl.drawLineEx(x1, y1, x2, y2, thickness, _extractColor(color))
end

fn drawRectangleLines(x, y, w, h, color)
    rl.drawRectangleLines(x, y, w, h, _extractColor(color))
end

fn drawRectangleGradientV(x, y, w, h, color1, color2)
    rl.drawRectangleGradientV(x, y, w, h, _extractColor(color1), _extractColor(color2))
end

fn drawTriangle(v1x, v1y, v2x, v2y, v3x, v3y, color)
    rl.drawTriangle(v1x, v1y, v2x, v2y, v3x, v3y, _extractColor(color))
end

fn drawTriangleLines(v1x, v1y, v2x, v2y, v3x, v3y, color)
    rl.drawTriangleLines(v1x, v1y, v2x, v2y, v3x, v3y, _extractColor(color))
end

fn drawPoly(x, y, sides, radius, rotation, color)
    rl.drawPoly(x, y, sides, radius, rotation, _extractColor(color))
end

fn drawRectangleRounded(x, y, w, h, roundness, segments, color)
    rl.drawRectangleRounded(x, y, w, h, roundness, segments, _extractColor(color))
end

fn drawEllipse(centerX, centerY, radiusH, radiusV, color)
    rl.drawEllipse(centerX, centerY, radiusH, radiusV, _extractColor(color))
end

