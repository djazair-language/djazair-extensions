use webview

let app = webview.createWindow({
    "title": "TEST GetInfo",
    "width": 900,
    "height": 650,
    "debug": True
})

app.onReady(fn()
    app.bridge.on("getInfo", fn(p)
        return {
            "title":    app.window.title(),
            "size":     app.window.getSize(),
            "position": app.window.getPosition(),
            "zoom":     app.window.zoomLevel(),
            "visible":  app.window.isVisible(),
            "maximized":app.window.isMaximized(),
            "minimized":app.window.isMinimized()
        }
    end)

    app.window.setHtml("
        <!DOCTYPE html>
        <html>
        <body>
            <div id='log'></div>
            <script>
                async function run() {
                    var log = document.getElementById('log');
                    try {
                        var r = await window.djazair.invoke('getInfo');
                        log.innerHTML = 'SUCCESS: ' + JSON.stringify(r);
                        window.djazair.invoke('quit', 'SUCCESS');
                    } catch (e) {
                        log.innerHTML = 'ERROR: ' + e.message;
                        window.djazair.invoke('quit', 'ERROR: ' + e.message);
                    }
                }
                run();
            </script>
        </body>
        </html>
    ")
end)

app.bridge.on("quit", fn(p)
    print(p)
    app.quit()
end)

app.run()
