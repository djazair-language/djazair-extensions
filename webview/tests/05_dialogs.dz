use webview

# ══════════════════════════════════════════════════════════════════
#  TEST 05 — Dialogs
#  Tests:
#    • showMessageBox  (info / warning / error, ok/yesno/okcancel)
#    • showOpenFileDialog (single, multi, with filters)
#    • showSaveFileDialog
#    • showOpenFolderDialog
#    • showColorPicker
#    • Null return when user cancels
# ══════════════════════════════════════════════════════════════════

let app = webview.createWindow({
    "title": "TEST 05 — System Dialogs",
    "width": 900,
    "height": 680,
    "debug": True
})

app.onReady(fn()

    # ── Message boxes ─────────────────────────────────────────────
    app.bridge.on("msgInfo", fn(p)
        let r = webview.showMessageBox({
            "type": "info",
            "title": "Information",
            "message": "This is an info dialog.",
            "detail": "Click OK to confirm.",
            "buttons": "ok"
        })
        return { "result": r }
    end)

    app.bridge.on("msgWarning", fn(p)
        let r = webview.showMessageBox({
            "type": "warning",
            "title": "Warning",
            "message": "Are you sure?",
            "buttons": "yesno"
        })
        return { "result": r, "clicked": r }
    end)

    app.bridge.on("msgError", fn(p)
        let r = webview.showMessageBox({
            "type": "error",
            "title": "Error",
            "message": "Something went wrong.",
            "buttons": "okcancel"
        })
        return { "result": r }
    end)

    # ── File dialogs ──────────────────────────────────────────────
    app.bridge.on("openFile", fn(p)
        let path = webview.showOpenFileDialog({
            "title": "Select Any File",
            "filters": [
                { "name": "All Files", "extensions": ["*"] }
            ]
        })
        if isNull(path)
            return { "selected": Null, "cancelled": True }
        end
        return { "selected": path, "cancelled": False }
    end)

    app.bridge.on("openFileFiltered", fn(p)
        let path = webview.showOpenFileDialog({
            "title": "Select Source File",
            "filters": [
                { "name": "Djazair Source", "extensions": ["dz"] },
                { "name": "Text Files",     "extensions": ["txt", "md"] },
                { "name": "All Files",      "extensions": ["*"] }
            ]
        })
        if isNull(path)
            return { "selected": Null, "cancelled": True }
        end
        return { "selected": path, "cancelled": False }
    end)

    app.bridge.on("openMulti", fn(p)
        let paths = webview.showOpenFileDialog({
            "title": "Select Multiple Files",
            "multiSelections": True,
            "filters": [{ "name": "All Files", "extensions": ["*"] }]
        })
        if isNull(paths)
            return { "selected": [], "count": 0, "cancelled": True }
        end
        return { "selected": paths, "count": paths.length(), "cancelled": False }
    end)

    app.bridge.on("saveFile", fn(p)
        let path = webview.showSaveFileDialog({
            "title": "Save File As",
            "defaultPath": "output.json",
            "filters": [
                { "name": "JSON", "extensions": ["json"] },
                { "name": "Text", "extensions": ["txt"] }
            ]
        })
        if isNull(path)
            return { "selected": Null, "cancelled": True }
        end
        return { "selected": path, "cancelled": False }
    end)

    app.bridge.on("openFolder", fn(p)
        let path = webview.showOpenFolderDialog({
            "title": "Select a Folder"
        })
        if isNull(path)
            return { "selected": Null, "cancelled": True }
        end
        return { "selected": path, "cancelled": False }
    end)

    app.bridge.on("pickColor", fn(p)
        let color = webview.showColorPicker({
            "title": "Pick a Color"
        })
        return { "color": color }
    end)

    app.window.setHtml("
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset='UTF-8'>
            <style>
                * { box-sizing: border-box; margin: 0; padding: 0; }
                body { font-family: 'Segoe UI', sans-serif; background: #0d1117; color: #c9d1d9; padding: 20px; }
                h1 { color: #d2a8ff; margin-bottom: 14px; font-size: 1.2rem; }
                .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 10px; }
                button {
                    background: #21262d; border: 1px solid #30363d;
                    color: #d2a8ff; padding: 9px 12px; border-radius: 6px;
                    cursor: pointer; font-size: 12px; transition: background 0.15s;
                }
                button:hover { background: #30363d; }
                #log {
                    background: #161b22; border: 1px solid #30363d;
                    border-radius: 6px; padding: 12px; height: 360px;
                    overflow-y: auto; font-size: 12px; line-height: 1.6; font-family: monospace;
                }
                .pass { color: #3fb950; } .fail { color: #f85149; }
                .info { color: #8b949e; } .result { color: #d2a8ff; }
            </style>
        </head>
        <body>
            <h1>TEST 05 — System Dialogs</h1>
            <p style='font-size:11px;color:#8b949e;margin-bottom:10px;'>
                Each test opens a real OS dialog. Interact with it — results shown below.
            </p>
            <div class='grid'>
                <button onclick='testMsgInfo()'>① MessageBox (info)</button>
                <button onclick='testMsgWarning()'>② MessageBox (yesno)</button>
                <button onclick='testMsgError()'>③ MessageBox (okcancel)</button>
                <button onclick='testOpenFile()'>④ Open File (any)</button>
                <button onclick='testOpenFiltered()'>⑤ Open File (filtered)</button>
                <button onclick='testOpenMulti()'>⑥ Open File (multi)</button>
                <button onclick='testSaveFile()'>⑦ Save File Dialog</button>
                <button onclick='testOpenFolder()'>⑧ Open Folder Dialog</button>
                <button onclick='testColorPicker()'>⑨ Color Picker</button>
            </div>
            <div id='log'><span class='info'>Click a dialog test — interact with the dialog that appears.</span></div>

            <script>
                var logDiv = document.getElementById('log');
                function write(msg, cls) {
                    var ts = new Date().toLocaleTimeString('en',{hour12:false});
                    logDiv.innerHTML += '<div class=\"'+(cls||'info')+'\">['+ts+'] '+msg+'</div>';
                    logDiv.scrollTop = logDiv.scrollHeight;
                }
                function pass(m)   { write('✔ PASS: '+m, 'pass'); }
                function fail(m)   { write('✘ FAIL: '+m, 'fail'); }
                function info(m)   { write('  '+m, 'info'); }
                function result(m) { write('  → '+m, 'result'); }
                function assert(c, m) { if(c) pass(m); else fail(m); }

                async function testMsgInfo() {
                    info('--- MessageBox info (click OK) ---');
                    var r = await window.djazair.invoke('msgInfo');
                    result('Result: ' + JSON.stringify(r));
                    assert(r !== null && r !== undefined, 'got result object');
                    assert(typeof r.result !== 'undefined', 'result field present: ' + r.result);
                }

                async function testMsgWarning() {
                    info('--- MessageBox yesno (click Yes or No) ---');
                    var r = await window.djazair.invoke('msgWarning');
                    result('Result: ' + JSON.stringify(r));
                    assert(r !== null, 'got result');
                }

                async function testMsgError() {
                    info('--- MessageBox error/okcancel ---');
                    var r = await window.djazair.invoke('msgError');
                    result('Result: ' + JSON.stringify(r));
                    assert(r !== null, 'got result');
                }

                async function testOpenFile() {
                    info('--- Open File Dialog (select any file or cancel) ---');
                    var r = await window.djazair.invoke('openFile');
                    result('Result: ' + JSON.stringify(r));
                    assert(typeof r.cancelled === 'boolean', 'cancelled is bool: ' + r.cancelled);
                    if (!r.cancelled) {
                        assert(typeof r.selected === 'string' && r.selected.length > 0,
                               'selected path: ' + r.selected);
                    } else {
                        pass('User cancelled — got Null correctly');
                    }
                }

                async function testOpenFiltered() {
                    info('--- Open File Dialog (filtered: .dz .txt .md) ---');
                    var r = await window.djazair.invoke('openFileFiltered');
                    result('Result: ' + JSON.stringify(r));
                    assert(typeof r.cancelled === 'boolean', 'got valid result');
                    if (!r.cancelled) {
                        pass('Selected: ' + r.selected);
                    } else {
                        pass('Cancelled correctly');
                    }
                }

                async function testOpenMulti() {
                    info('--- Open File Dialog (multi-select: Ctrl+Click) ---');
                    var r = await window.djazair.invoke('openMulti');
                    result('Result: count=' + r.count + ' cancelled=' + r.cancelled);
                    assert(typeof r.count === 'number', 'count is number: ' + r.count);
                    if (!r.cancelled && r.count > 0) {
                        assert(Array.isArray(r.selected), 'selected is array');
                        pass('Selected ' + r.count + ' file(s)');
                    } else {
                        pass('No selection or cancelled');
                    }
                }

                async function testSaveFile() {
                    info('--- Save File Dialog ---');
                    var r = await window.djazair.invoke('saveFile');
                    result('Result: ' + JSON.stringify(r));
                    assert(typeof r.cancelled === 'boolean', 'got valid result');
                    if (!r.cancelled) {
                        assert(typeof r.selected === 'string', 'save path: ' + r.selected);
                    } else {
                        pass('Cancelled correctly');
                    }
                }

                async function testOpenFolder() {
                    info('--- Open Folder Dialog ---');
                    var r = await window.djazair.invoke('openFolder');
                    result('Result: ' + JSON.stringify(r));
                    assert(typeof r.cancelled === 'boolean', 'got valid result');
                    if (!r.cancelled) {
                        assert(typeof r.selected === 'string', 'folder path: ' + r.selected);
                    } else {
                        pass('Cancelled correctly');
                    }
                }

                async function testColorPicker() {
                    info('--- Color Picker Dialog ---');
                    var r = await window.djazair.invoke('pickColor');
                    result('Result: ' + JSON.stringify(r));
                    pass('Color picker returned: ' + JSON.stringify(r.color));
                }
            </script>
        </body>
        </html>
    ")
end)

app.run()
