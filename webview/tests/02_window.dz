use webview

# ══════════════════════════════════════════════════════════════════
#  TEST 02 — Window Management
#  Tests:
#    • setTitle / title
#    • setSize / getSize
#    • setPosition / getPosition
#    • minimize / maximize / restore
#    • isMinimized / isMaximized / isVisible
#    • hide / show
#    • setResizable / setMinimumSize / setMaximumSize
#    • setBackgroundColor
#    • setZoomLevel / zoomLevel
#    • setContextMenuEnabled
# ══════════════════════════════════════════════════════════════════

let app = webview.createWindow({
    "title": "TEST 02 — Window Management",
    "width": 900,
    "height": 650,
    "debug": True
})

app.onReady(fn()

    # ── Bridge handlers that execute window operations ─────────────
    app.bridge.on("getInfo", fn(p)
        return {
            "title":    app.window.title(),
            "size":     app.window.getSize(),
            "position": app.window.getPosition(),
            "zoom":     app.window.zoomLevel(),
            "visible":  app.window.isVisible(),
            "maximized":app.window.isMaximized(),
            "minimized":app.window.isMinimized()
        }
    end)

    app.bridge.on("setTitle", fn(p)
        app.window.setTitle(p["title"])
        return app.window.title()
    end)

    app.bridge.on("setSize", fn(p)
        app.window.setSize(p["w"], p["h"])
        return app.window.getSize()
    end)

    app.bridge.on("setPosition", fn(p)
        app.window.setPosition(p["x"], p["y"])
        return app.window.getPosition()
    end)

    app.bridge.on("minimize", fn(p)
        app.window.minimize()
        return True
    end)

    app.bridge.on("maximize", fn(p)
        app.window.maximize()
        return True
    end)

    app.bridge.on("restore", fn(p)
        app.window.restore()
        return True
    end)

    app.bridge.on("setZoom", fn(p)
        app.window.setZoomLevel(p["level"])
        return app.window.zoomLevel()
    end)

    app.bridge.on("setResizable", fn(p)
        app.window.setResizable(p["value"])
        return True
    end)

    app.bridge.on("setMinSize", fn(p)
        app.window.setMinimumSize(p["w"], p["h"])
        return True
    end)

    app.bridge.on("setMaxSize", fn(p)
        app.window.setMaximumSize(p["w"], p["h"])
        return True
    end)

    app.bridge.on("setBgColor", fn(p)
        app.window.setBackgroundColor(p["r"], p["g"], p["b"])
        return True
    end)

    app.bridge.on("setContextMenu", fn(p)
        app.window.setContextMenuEnabled(p["enabled"])
        return True
    end)

    app.window.setHtml("
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset='UTF-8'>
            <style>
                * { box-sizing: border-box; margin: 0; padding: 0; }
                body { font-family: 'Segoe UI', sans-serif; background: #0d1117; color: #c9d1d9; padding: 20px; }
                h1 { color: #58a6ff; margin-bottom: 14px; font-size: 1.2rem; }
                .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
                button {
                    background: #21262d; border: 1px solid #30363d;
                    color: #58a6ff; padding: 9px 10px; border-radius: 6px;
                    cursor: pointer; font-size: 12px; text-align: left;
                    transition: background 0.15s;
                }
                button:hover { background: #30363d; }
                #log {
                    margin-top: 14px; background: #161b22;
                    border: 1px solid #30363d; border-radius: 6px;
                    padding: 12px; height: 300px; overflow-y: auto;
                    font-size: 12px; line-height: 1.6; font-family: monospace;
                }
                .pass { color: #3fb950; } .fail { color: #f85149; } .info { color: #8b949e; }
            </style>
        </head>
        <body>
            <h1>TEST 02 — Window Management</h1>
            <div class='grid'>
                <button onclick='testTitle()'>① Set/Get Title</button>
                <button onclick='testSize()'>② Set/Get Size</button>
                <button onclick='testPosition()'>③ Set/Get Position</button>
                <button onclick='testMinimize()'>④ Minimize → Restore</button>
                <button onclick='testMaximize()'>⑤ Maximize → Restore</button>
                <button onclick='testZoom()'>⑥ Zoom Level</button>
                <button onclick='testResizable()'>⑦ Resizable toggle</button>
                <button onclick='testSizeConstraints()'>⑧ Min/Max Size</button>
                <button onclick='testBgColor()'>⑨ Background Color</button>
                <button onclick='testContextMenu()'>⑩ Context Menu toggle</button>
                <button onclick='testGetInfo()'>⑪ getInfo snapshot</button>
                <button onclick='runAll()'>▶ RUN ALL</button>
            </div>
            <div id='log'><span class='info'>Click a test...</span></div>

            <script>
                var log = document.getElementById('log');
                function write(msg, cls) {
                    var ts = new Date().toLocaleTimeString('en',{hour12:false});
                    log.innerHTML += '<div class=\"'+(cls||'info')+'\">['+ts+'] '+msg+'</div>';
                    log.scrollTop = log.scrollHeight;
                }
                function pass(m) { write('✔ PASS: '+m, 'pass'); }
                function fail(m) { write('✘ FAIL: '+m, 'fail'); }
                function info(m) { write('  '+m, 'info'); }
                function clearLog() { log.innerHTML = ''; }
                function assert(c, m) { if(c) pass(m); else fail(m); }

                async function testTitle() {
                    info('--- Title Test ---');
                    var r = await window.djazair.invoke('setTitle', { title: 'Modified Title ✓' });
                    assert(r === 'Modified Title ✓', 'title = ' + r);
                    await window.djazair.invoke('setTitle', { title: 'TEST 02 — Window Management' });
                }

                async function testSize() {
                    info('--- Size Test ---');
                    var r = await window.djazair.invoke('setSize', { w: 800, h: 600 });
                    assert(r[0] === 800 && r[1] === 600, 'size = ' + JSON.stringify(r));
                    await window.djazair.invoke('setSize', { w: 900, h: 650 });
                }

                async function testPosition() {
                    info('--- Position Test ---');
                    var r = await window.djazair.invoke('setPosition', { x: 100, y: 100 });
                    assert(Array.isArray(r), 'position returned: ' + JSON.stringify(r));
                }

                async function testMinimize() {
                    info('--- Minimize/Restore Test ---');
                    var r = await window.djazair.invoke('minimize');
                    assert(r === true, 'minimize called');
                    await new Promise(res => setTimeout(res, 500));
                    var r2 = await window.djazair.invoke('restore');
                    assert(r2 === true, 'restore called');
                }

                async function testMaximize() {
                    info('--- Maximize/Restore Test ---');
                    var r = await window.djazair.invoke('maximize');
                    assert(r === true, 'maximize called');
                    await new Promise(res => setTimeout(res, 400));
                    var r2 = await window.djazair.invoke('restore');
                    assert(r2 === true, 'restore called');
                }

                async function testZoom() {
                    info('--- Zoom Test ---');
                    var r1 = await window.djazair.invoke('setZoom', { level: 1.5 });
                    assert(r1 >= 1.0, 'zoom set: ' + r1);
                    await new Promise(res => setTimeout(res, 300));
                    var r2 = await window.djazair.invoke('setZoom', { level: 1.0 });
                    assert(r2 >= 0.9, 'zoom reset: ' + r2);
                }

                async function testResizable() {
                    info('--- Resizable Test ---');
                    var r1 = await window.djazair.invoke('setResizable', { value: false });
                    assert(r1 === true, 'setResizable(false)');
                    await new Promise(res => setTimeout(res, 300));
                    var r2 = await window.djazair.invoke('setResizable', { value: true });
                    assert(r2 === true, 'setResizable(true)');
                }

                async function testSizeConstraints() {
                    info('--- Min/Max Size Test ---');
                    var r1 = await window.djazair.invoke('setMinSize', { w: 400, h: 300 });
                    assert(r1 === true, 'setMinimumSize(400,300)');
                    var r2 = await window.djazair.invoke('setMaxSize', { w: 1920, h: 1080 });
                    assert(r2 === true, 'setMaximumSize(1920,1080)');
                }

                async function testBgColor() {
                    info('--- Background Color Test ---');
                    var r = await window.djazair.invoke('setBgColor', { r: 13, g: 17, b: 23 });
                    assert(r === true, 'setBackgroundColor(13,17,23)');
                }

                async function testContextMenu() {
                    info('--- Context Menu Toggle Test ---');
                    var r1 = await window.djazair.invoke('setContextMenu', { enabled: false });
                    assert(r1 === true, 'disabled context menu');
                    var r2 = await window.djazair.invoke('setContextMenu', { enabled: true });
                    assert(r2 === true, 'enabled context menu');
                }

                async function testGetInfo() {
                    info('--- GetInfo Snapshot ---');
                    var r = await window.djazair.invoke('getInfo');
                    assert(typeof r.title === 'string',         'title is string: '+r.title);
                    assert(Array.isArray(r.size),               'size is array: '+JSON.stringify(r.size));
                    assert(Array.isArray(r.position),           'position is array');
                    assert(typeof r.zoom === 'number',          'zoom is number: '+r.zoom);
                    assert(typeof r.visible === 'boolean',      'visible is bool: '+r.visible);
                    assert(typeof r.maximized === 'boolean',    'maximized is bool');
                    assert(typeof r.minimized === 'boolean',    'minimized is bool');
                    info('Snapshot: ' + JSON.stringify(r));
                }

                async function runAll() {
                    try {
                        clearLog();
                        info('=== Running all window tests ===');
                        await testGetInfo();
                        await testTitle();
                        await testSize();
                        await testPosition();
                        await testZoom();
                        await testResizable();
                        await testSizeConstraints();
                        await testBgColor();
                        await testContextMenu();
                        await testMinimize();
                        await testMaximize();
                        info('=== Done ===');
                    } catch (e) {
                        fail('JS Error: ' + e.message);
                    }
                }
            </script>
        </body>
        </html>
    ")
end)

app.run()
