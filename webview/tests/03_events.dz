use webview

# ══════════════════════════════════════════════════════════════════
#  TEST 03 — Window Events
#  Tests:
#    • onClose callback
#    • onMove callback (x, y coordinates)
#    • onResize callback (width, height)
#    • onFocus / onBlur callbacks
#    • onMaximize / onMinimize / onRestore callbacks
#    • onLoad callback
#    • onNavigate callback
#    • onTitleChange callback
# ══════════════════════════════════════════════════════════════════

use json as *

let app = webview.createWindow({
    "title": "TEST 03 — Window Events",
    "width": 900,
    "height": 650,
    "debug": True
})

# Shared event log — each event fires bridge.send to JS
let eventLog = []

app.onReady(fn()

    # ── Register all window event callbacks ───────────────────────
    app.window.onMove(fn(x, y)
        let entry = { "event": "move", "x": x, "y": y }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onResize(fn(w, h)
        let entry = { "event": "resize", "w": w, "h": h }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onFocus(fn()
        let entry = { "event": "focus" }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onBlur(fn()
        let entry = { "event": "blur" }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onMaximize(fn()
        let entry = { "event": "maximize" }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onMinimize(fn()
        let entry = { "event": "minimize" }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onRestore(fn()
        let entry = { "event": "restore" }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onLoad(fn()
        let entry = { "event": "load", "url": app.window.getUrl() }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onNavigate(fn(url)
        let entry = { "event": "navigate", "url": url }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    app.window.onTitleChange(fn(title)
        let entry = { "event": "titleChange", "title": title }
        eventLog.append(entry)
        app.bridge.send("windowEvent", entry)
    end)

    # ── Bridge: query logged events ───────────────────────────────
    app.bridge.on("getLog", fn(p)
        return eventLog
    end)

    app.bridge.on("clearLog", fn(p)
        eventLog.clear()
        return True
    end)

    app.bridge.on("countEvent", fn(p)
        let name = p["name"]
        let count = 0
        for entry in eventLog
            if entry["event"] == name
                count = count + 1
            end
        end
        return count
    end)

    # ── Trigger events via bridge ─────────────────────────────────
    app.bridge.on("doMinimize", fn(p)
        app.window.minimize()
        return True
    end)

    app.bridge.on("doMaximize", fn(p)
        app.window.maximize()
        return True
    end)

    app.bridge.on("doRestore", fn(p)
        app.window.restore()
        return True
    end)

    app.bridge.on("doResize", fn(p)
        app.window.setSize(p["w"], p["h"])
        return True
    end)

    app.bridge.on("doMove", fn(p)
        app.window.setPosition(p["x"], p["y"])
        return True
    end)

    app.window.setHtml("
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset='UTF-8'>
            <style>
                * { box-sizing: border-box; margin: 0; padding: 0; }
                body { font-family: 'Segoe UI', sans-serif; background: #0d1117; color: #c9d1d9; padding: 20px; }
                h1 { color: #f0883e; margin-bottom: 14px; font-size: 1.2rem; }
                .row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
                button {
                    background: #21262d; border: 1px solid #30363d;
                    color: #f0883e; padding: 9px 14px; border-radius: 6px;
                    cursor: pointer; font-size: 12px; transition: background 0.15s;
                }
                button:hover { background: #30363d; }
                #events {
                    background: #161b22; border: 1px solid #30363d;
                    border-radius: 6px; padding: 12px; height: 200px;
                    overflow-y: auto; font-size: 12px; line-height: 1.6; font-family: monospace;
                    margin-bottom: 10px;
                }
                #log {
                    background: #161b22; border: 1px solid #30363d;
                    border-radius: 6px; padding: 12px; height: 160px;
                    overflow-y: auto; font-size: 12px; line-height: 1.6; font-family: monospace;
                }
                .ev   { color: #d2a8ff; }
                .pass { color: #3fb950; } .fail { color: #f85149; } .info { color: #8b949e; }
                label { font-size: 11px; color: #8b949e; display: block; margin-bottom: 4px; }
            </style>
        </head>
        <body>
            <h1>TEST 03 — Window Events</h1>

            <div class='row'>
                <button onclick='triggerResize()'>Trigger Resize</button>
                <button onclick='triggerMove()'>Trigger Move</button>
                <button onclick='triggerMinimize()'>Trigger Minimize</button>
                <button onclick='triggerMaximize()'>Trigger Maximize</button>
                <button onclick='triggerRestore()'>Trigger Restore</button>
                <button onclick='clearEvents()'>Clear Log</button>
            </div>
            <div class='row'>
                <button onclick='testResizeEvent()'>① Assert resize event</button>
                <button onclick='testMoveEvent()'>② Assert move event</button>
                <button onclick='testMinMaxRestore()'>③ min/max/restore sequence</button>
                <button onclick='testLoadEvent()'>④ Load event fired</button>
                <button onclick='runAll()'>▶ RUN ALL</button>
            </div>

            <label>Live Events (from bridge.send):</label>
            <div id='events'><span class='info'>Move or resize the window...</span></div>

            <label>Test Results:</label>
            <div id='log'></div>

            <script>
                var evDiv = document.getElementById('events');
                var logDiv = document.getElementById('log');

                // Listen for all window events pushed from Djazair
                window.djazair.on('windowEvent', function(data) {
                    var ts = new Date().toLocaleTimeString('en',{hour12:false});
                    evDiv.innerHTML += '<div class=\"ev\">['+ts+'] '+JSON.stringify(data)+'</div>';
                    evDiv.scrollTop = evDiv.scrollHeight;
                });

                function write(msg, cls) {
                    var ts = new Date().toLocaleTimeString('en',{hour12:false});
                    logDiv.innerHTML += '<div class=\"'+(cls||'info')+'\">['+ts+'] '+msg+'</div>';
                    logDiv.scrollTop = logDiv.scrollHeight;
                }
                function pass(m) { write('✔ PASS: '+m, 'pass'); }
                function fail(m) { write('✘ FAIL: '+m, 'fail'); }
                function info(m) { write('  '+m, 'info'); }
                function assert(c, m) { if(c) pass(m); else fail(m); }

                async function clearEvents() {
                    evDiv.innerHTML = '';
                    await window.djazair.invoke('clearLog');
                }

                async function triggerResize() {
                    await window.djazair.invoke('doResize', { w: 800, h: 500 });
                    await new Promise(res => setTimeout(res, 200));
                    await window.djazair.invoke('doResize', { w: 900, h: 650 });
                }
                async function triggerMove() {
                    await window.djazair.invoke('doMove', { x: 200, y: 150 });
                }
                async function triggerMinimize() {
                    await window.djazair.invoke('doMinimize');
                    await new Promise(res => setTimeout(res, 500));
                    await window.djazair.invoke('doRestore');
                }
                async function triggerMaximize() {
                    await window.djazair.invoke('doMaximize');
                }
                async function triggerRestore() {
                    await window.djazair.invoke('doRestore');
                }

                async function testResizeEvent() {
                    info('--- Resize Event Test ---');
                    await window.djazair.invoke('clearLog');
                    await window.djazair.invoke('doResize', { w: 750, h: 550 });
                    await new Promise(res => setTimeout(res, 300));
                    var count = await window.djazair.invoke('countEvent', { name: 'resize' });
                    assert(count >= 1, 'resize event fired >= 1 time (got ' + count + ')');
                    var log = await window.djazair.invoke('getLog');
                    var ev = log.find(function(e){ return e.event === 'resize'; });
                    assert(ev && ev.w > 0, 'resize has width: ' + (ev ? ev.w : 'N/A'));
                    assert(ev && ev.h > 0, 'resize has height: ' + (ev ? ev.h : 'N/A'));
                    await window.djazair.invoke('doResize', { w: 900, h: 650 });
                }

                async function testMoveEvent() {
                    info('--- Move Event Test ---');
                    await window.djazair.invoke('clearLog');
                    await window.djazair.invoke('doMove', { x: 150, y: 120 });
                    await new Promise(res => setTimeout(res, 300));
                    var count = await window.djazair.invoke('countEvent', { name: 'move' });
                    assert(count >= 1, 'move event fired >= 1 time (got ' + count + ')');
                    var log = await window.djazair.invoke('getLog');
                    var ev = log.find(function(e){ return e.event === 'move'; });
                    assert(ev && typeof ev.x === 'number', 'move has x coord: ' + (ev ? ev.x : 'N/A'));
                    assert(ev && typeof ev.y === 'number', 'move has y coord: ' + (ev ? ev.y : 'N/A'));
                }

                async function testMinMaxRestore() {
                    info('--- Minimize/Maximize/Restore Sequence ---');
                    await window.djazair.invoke('clearLog');
                    await window.djazair.invoke('doMinimize');
                    await new Promise(res => setTimeout(res, 600));
                    await window.djazair.invoke('doRestore');
                    await new Promise(res => setTimeout(res, 400));
                    await window.djazair.invoke('doMaximize');
                    await new Promise(res => setTimeout(res, 400));
                    await window.djazair.invoke('doRestore');
                    await new Promise(res => setTimeout(res, 300));
                    var log = await window.djazair.invoke('getLog');
                    var events = log.map(function(e){ return e.event; });
                    info('Event sequence: ' + JSON.stringify(events));
                    assert(events.indexOf('minimize') >= 0,   'minimize event fired');
                    assert(events.indexOf('restore')  >= 0,   'restore event fired');
                    assert(events.indexOf('maximize') >= 0,   'maximize event fired');
                }

                async function testLoadEvent() {
                    info('--- Load Event Test ---');
                    var log = await window.djazair.invoke('getLog');
                    var ev = log.find(function(e){ return e.event === 'load'; });
                    // Load fires when page loads, may have already happened
                    info('Load events found: ' + log.filter(function(e){return e.event==='load';}).length);
                    pass('load event check complete (see live events panel)');
                }

                async function runAll() {
                    logDiv.innerHTML = '';
                    evDiv.innerHTML = '';
                    info('=== Running all event tests ===');
                    await testResizeEvent();
                    await testMoveEvent();
                    await testMinMaxRestore();
                    await testLoadEvent();
                    info('=== Done ===');
                }
            </script>
        </body>
        </html>
    ")
end)

app.run()
