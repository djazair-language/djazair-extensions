use webview

# ══════════════════════════════════════════════════════════════════
#  TEST 04 — Navigation & Content
#  Tests:
#    • navigate(url) — external https URL
#    • setHtml() — inline HTML
#    • eval() — execute JS from Djazair side
#    • initJs() — preload script injection
#    • reload()
#    • goBack() / goForward() / canGoBack() / canGoForward()
#    • getUrl()
#    • setZoomLevel / zoomLevel
#    • bridge.expose() — direct global function binding
# ══════════════════════════════════════════════════════════════════

let app = webview.createWindow({
    "title": "TEST 04 — Navigation & Content",
    "width": 950,
    "height": 680,
    "debug": True
})

app.onReady(fn()

    # ── bridge.expose: native function directly on window ─────────
    app.bridge.expose("nativeAdd", fn(args)
        # args = the raw JS arguments array
        return args[0] + args[1]
    end)

    app.bridge.expose("nativeGreet", fn(args)
        return "Hello, " + args[0] + "! From Djazair native binding."
    end)

    # ── bridge.on handlers ────────────────────────────────────────
    app.bridge.on("getUrl", fn(p)
        return app.window.getUrl()
    end)

    app.bridge.on("canGoBack", fn(p)
        return app.window.canGoBack()
    end)

    app.bridge.on("canGoForward", fn(p)
        return app.window.canGoForward()
    end)

    app.bridge.on("goBack", fn(p)
        app.window.goBack()
        return True
    end)

    app.bridge.on("goForward", fn(p)
        app.window.goForward()
        return True
    end)

    app.bridge.on("reload", fn(p)
        app.window.reload()
        return True
    end)

    app.bridge.on("setZoom", fn(p)
        app.window.setZoomLevel(p["level"])
        return app.window.zoomLevel()
    end)

    app.bridge.on("evalInPage", fn(p)
        # eval a JS expression from Djazair and return result via push
        let code = p["code"]
        app.window.eval("window.djazair.send('evalResult', { result: (" + code + ") })")
        return True
    end)

    app.bridge.on("navigateTo", fn(p)
        app.window.navigate(p["url"])
        return True
    end)

    app.window.setHtml("
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset='UTF-8'>
            <style>
                * { box-sizing: border-box; margin: 0; padding: 0; }
                body { font-family: 'Segoe UI', sans-serif; background: #0d1117; color: #c9d1d9; padding: 20px; }
                h1 { color: #3fb950; margin-bottom: 14px; font-size: 1.2rem; }
                .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 10px; }
                button {
                    background: #21262d; border: 1px solid #30363d;
                    color: #3fb950; padding: 9px 12px; border-radius: 6px;
                    cursor: pointer; font-size: 12px; transition: background 0.15s;
                }
                button:hover { background: #30363d; }
                #log {
                    background: #161b22; border: 1px solid #30363d;
                    border-radius: 6px; padding: 12px; height: 340px;
                    overflow-y: auto; font-size: 12px; line-height: 1.6; font-family: monospace;
                }
                .pass { color: #3fb950; } .fail { color: #f85149; } .info { color: #8b949e; }
            </style>
        </head>
        <body>
            <h1>TEST 04 — Navigation & Content</h1>
            <div class='grid'>
                <button onclick='testGetUrl()'>① getUrl()</button>
                <button onclick='testCanGoBack()'>② canGoBack/Forward</button>
                <button onclick='testEval()'>③ eval() from Djazair</button>
                <button onclick='testExpose()'>④ bridge.expose()</button>
                <button onclick='testZoomNav()'>⑤ Zoom levels</button>
                <button onclick='testInitJsVars()'>⑥ initJs variables</button>
                <button onclick='runAll()'>▶ RUN ALL</button>
                <button onclick='clearLog()'>✕ Clear</button>
            </div>
            <div id='log'><span class='info'>Click a test...</span></div>

            <script>
                var logDiv = document.getElementById('log');

                // Listen for eval results pushed back
                window.djazair.on('evalResult', function(data) {
                    info('eval() result received: ' + JSON.stringify(data.result));
                });

                function write(msg, cls) {
                    var ts = new Date().toLocaleTimeString('en',{hour12:false});
                    logDiv.innerHTML += '<div class=\"'+(cls||'info')+'\">['+ts+'] '+msg+'</div>';
                    logDiv.scrollTop = logDiv.scrollHeight;
                }
                function pass(m) { write('✔ PASS: '+m, 'pass'); }
                function fail(m) { write('✘ FAIL: '+m, 'fail'); }
                function info(m) { write('  '+m, 'info'); }
                function clearLog() { logDiv.innerHTML = ''; }
                function assert(c, m) { if(c) pass(m); else fail(m); }

                // ① getUrl
                async function testGetUrl() {
                    info('--- getUrl() Test ---');
                    var url = await window.djazair.invoke('getUrl');
                    assert(typeof url === 'string' && url.length > 0, 'url = ' + url);
                    assert(url.indexOf('http') === 0 || url.indexOf('about:') === 0,
                           'url starts with http or about:');
                }

                // ② canGoBack / canGoForward
                async function testCanGoBack() {
                    info('--- canGoBack/Forward Test ---');
                    var back = await window.djazair.invoke('canGoBack');
                    var fwd  = await window.djazair.invoke('canGoForward');
                    assert(typeof back === 'boolean', 'canGoBack is bool: ' + back);
                    assert(typeof fwd  === 'boolean', 'canGoForward is bool: ' + fwd);
                    info('canGoBack=' + back + '  canGoForward=' + fwd);
                }

                // ③ eval() - Djazair evaluates JS, result pushed back
                async function testEval() {
                    info('--- eval() Test ---');
                    // Trigger eval from Djazair side
                    await window.djazair.invoke('evalInPage', { code: '2 + 2' });
                    await window.djazair.invoke('evalInPage', { code: '\"hello\".toUpperCase()' });
                    await window.djazair.invoke('evalInPage', { code: '[1,2,3].map(x => x*2)' });
                    info('eval() calls sent — see evalResult events above');
                    pass('eval() fired without error');
                }

                // ④ bridge.expose() - direct global function
                async function testExpose() {
                    info('--- bridge.expose() Test ---');

                    // nativeAdd and nativeGreet are exposed directly on window
                    var sum = await window.nativeAdd(10, 32);
                    info('nativeAdd raw result: ' + JSON.stringify(sum));
                    // exposed functions wrap result in {__dz_ok, __dz_data}
                    var realSum = (sum && typeof sum === 'object' && '__dz_data' in sum)
                        ? sum.__dz_data : sum;
                    assert(realSum === 42, 'nativeAdd(10, 32) = ' + realSum);

                    var gr = await window.nativeGreet('World');
                    var realGr = (gr && typeof gr === 'object' && '__dz_data' in gr)
                        ? gr.__dz_data : gr;
                    assert(typeof realGr === 'string' && realGr.indexOf('Hello') >= 0,
                           'nativeGreet: ' + realGr);
                }

                // ⑤ Zoom levels
                async function testZoomNav() {
                    info('--- Zoom Level Test ---');
                    var levels = [0.5, 1.0, 1.25, 1.5, 2.0, 1.0];
                    for (var i = 0; i < levels.length; i++) {
                        var z = await window.djazair.invoke('setZoom', { level: levels[i] });
                        assert(typeof z === 'number', 'zoom at ' + levels[i] + ' → returned: ' + z);
                        await new Promise(res => setTimeout(res, 150));
                    }
                }

                // ⑥ initJs injected variable (injected before page load via initJs)
                async function testInitJsVars() {
                    info('--- initJs() Pre-injection Test ---');
                    // window.djazair itself is injected by initJs → bridge_client.js
                    assert(typeof window.djazair === 'object', 'window.djazair exists');
                    assert(typeof window.djazair.invoke === 'function', 'invoke is function');
                    assert(typeof window.djazair.on === 'function',     'on is function');
                    assert(typeof window.djazair.off === 'function',    'off is function');
                    assert(typeof window.djazair.send === 'function',   'send is function');
                    assert(typeof window.__dz_invoke === 'function',    '__dz_invoke binding exists');
                }

                async function runAll() {
                    clearLog();
                    info('=== Running all navigation & content tests ===');
                    await testGetUrl();
                    await testCanGoBack();
                    await testEval();
                    await testExpose();
                    await testZoomNav();
                    await testInitJsVars();
                    info('=== Done ===');
                }
            </script>
        </body>
        </html>
    ")
end)

app.run()
