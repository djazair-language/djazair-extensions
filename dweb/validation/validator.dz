# validation/validator.dz — Fluent Input Validator
#
# Usage:
#   let v = Validator(req.params)
#       .required("name")
#       .minLength("name", 3)
#       .required("email")
#       .email("email")
#       .required("age")
#       .number("age")
#       .min("age", 18)
#       .in("role", ["admin", "user", "guest"])
#
#   if !v.passes()
#       res.status(422).json({"errors": v.errors()})
#   end
#
#   let clean = v.validated()  # only validated & present fields

class Validator
    init(data)
        if isNull(data)
            data = {}
        end
        self._data   = data
        self._errors = {}
        self._fields = {}   # field → True (tracks which fields were validated)
    end

    # ─── Internal helper ──────────────────────────────────────────────────────
    _addError(field, msg)
        if !self._errors.has(field)
            self._errors[field] = []
        end
        self._errors[field].append(msg)
        return self
    end

    _get(field)
        return self._data.get(field, Null)
    end

    _track(field)
        self._fields[field] = True
    end

    # ─── Rules ────────────────────────────────────────────────────────────────

    # Field must be present and non-empty
    required(field)
        self._track(field)
        let val = self._get(field)
        if isNull(val) or str(val) == ""
            return self._addError(field, "The '${field}' field is required.")
        end
        return self
    end

    # Field is optional — skip other rules if absent
    optional(field)
        self._track(field)
        return self
    end

    # Value must be a string (or coercible to one)
    string(field)
        let val = self._get(field)
        if isNull(val) return self end
        if !isString(val)
            return self._addError(field, "The '${field}' field must be a string.")
        end
        return self
    end

    # Value must be numeric
    number(field)
        let val = self._get(field)
        if isNull(val) return self end
        let n = num(val)
        if isNull(n)
            return self._addError(field, "The '${field}' field must be a number.")
        end
        return self
    end

    # Value must be boolean-like (true/false/1/0)
    boolean(field)
        let val = self._get(field)
        if isNull(val) return self end
        let s = str(val).lower()
        if s != "true" and s != "false" and s != "1" and s != "0"
            return self._addError(field, "The '${field}' field must be a boolean.")
        end
        return self
    end

    # Minimum string length
    minLength(field, min)
        let val = self._get(field)
        if isNull(val) return self end
        if str(val).length() < min
            return self._addError(field, "The '${field}' field must be at least ${min} characters.")
        end
        return self
    end

    # Maximum string length
    maxLength(field, max)
        let val = self._get(field)
        if isNull(val) return self end
        if str(val).length() > max
            return self._addError(field, "The '${field}' field must not exceed ${max} characters.")
        end
        return self
    end

    # Minimum numeric value
    min(field, min_val)
        let val = self._get(field)
        if isNull(val) return self end
        let n = num(val)
        if isNull(n) or n < min_val
            return self._addError(field, "The '${field}' field must be at least ${min_val}.")
        end
        return self
    end

    # Maximum numeric value
    max(field, max_val)
        let val = self._get(field)
        if isNull(val) return self end
        let n = num(val)
        if isNull(n) or n > max_val
            return self._addError(field, "The '${field}' field must not exceed ${max_val}.")
        end
        return self
    end

    # Email format validation (basic RFC-like check)
    email(field)
        let val = self._get(field)
        if isNull(val) return self end
        let s = str(val)
        let at = s.index("@")
        if at == -1 or at <= 0
            return self._addError(field, "The '${field}' field must be a valid email address.")
        end
        let domain = s.slice(at + 1)
        let dot = domain.index(".")
        if dot == -1 or dot <= 0 or dot >= domain.length() - 1
            return self._addError(field, "The '${field}' field must be a valid email address.")
        end
        return self
    end

    # URL format validation
    url(field)
        let val = self._get(field)
        if isNull(val) return self end
        let s = str(val)
        if !s.startsWith("http://") and !s.startsWith("https://")
            return self._addError(field, "The '${field}' field must be a valid URL (http:// or https://).")
        end
        return self
    end

    # Value must be one of the provided choices
    oneOf(field, choices)
        let val = self._get(field)
        if isNull(val) return self end
        let s = str(val)
        let found = False
        for c in choices
            if str(c) == s
                found = True
                break
            end
        end
        if !found
            let joined = ""
            for i, c in choices
                if i > 0
                    joined += ", "
                end
                joined += str(c)
            end
            return self._addError(field, "The '${field}' field must be one of: ${joined}.")
        end
        return self
    end

    # Value must not be in the provided list
    notOneOf(field, choices)
        let val = self._get(field)
        if isNull(val) return self end
        let s = str(val)
        for c in choices
            if str(c) == s
                return self._addError(field, "The '${field}' field contains a forbidden value.")
            end
        end
        return self
    end

    # Value must match another field (e.g. password confirmation)
    same(field, other_field)
        let val = self._get(field)
        let other = self._get(other_field)
        if isNull(val) or isNull(other) return self end
        if str(val) != str(other)
            return self._addError(field, "The '${field}' field must match '${other_field}'.")
        end
        return self
    end

    # Value must NOT match another field
    different(field, other_field)
        let val = self._get(field)
        let other = self._get(other_field)
        if isNull(val) or isNull(other) return self end
        if str(val) == str(other)
            return self._addError(field, "The '${field}' field must be different from '${other_field}'.")
        end
        return self
    end

    # Custom validation rule: fn(value) → True | "error message"
    custom(field, rule_fn)
        let val = self._get(field)
        if isNull(val) return self end
        let result = rule_fn(val)
        if result != True
            let msg = str(result)
            if msg == "" then msg = "The '${field}' field is invalid." end
            return self._addError(field, msg)
        end
        return self
    end

    # ─── Result methods ───────────────────────────────────────────────────────

    # True if no validation errors
    passes()
        return self._errors.length() == 0
    end

    # True if there are validation errors
    fails()
        return !self.passes()
    end

    # Get all error messages as a Map { field: [messages] }
    errors()
        return self._errors
    end

    # Get the first error message for a specific field
    firstError(field)
        let errs = self._errors.get(field, Null)
        if isNull(errs) or errs.length() == 0
            return Null
        end
        return errs[0]
    end

    # Return only the fields that were validated and present (safe subset)
    validated()
        let result = {}
        let fields = self._fields.keys()
        for f in fields
            let val = self._get(f)
            if !isNull(val)
                result[f] = val
            end
        end
        return result
    end
end
