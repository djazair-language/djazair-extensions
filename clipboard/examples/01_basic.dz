# 01_basic.dz — Basic clipboard operations
use clipboard

print("Has: " + str(clipboard.has()))
print("Paste: '" + clipboard.paste() + "'")

clipboard.copy("Hello from Djazair!")
print("After copy - has: " + str(clipboard.has()))
print("Paste: '" + clipboard.paste() + "'")

clipboard.clear()
print("After clear - has: " + str(clipboard.has()))
print("Paste: '" + clipboard.paste() + "'")
